# Microsoft Graph (Azure AD App Registration)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
# Mailbox UPN to send from / monitor (e.g. organizer@yourdomain.com)
SENDER_USER_PRINCIPAL_NAME=

# Graph webhook subscription settings
# Must be PUBLIC https URL reachable by Microsoft (e.g. from ngrok)
PUBLIC_BASE_URL=
# Any random string; Graph will echo it back in notifications
GRAPH_CLIENT_STATE=change-me

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# App settings
DB_PATH=./data/app.db
APP_BASE_URL=http://localhost:8000
