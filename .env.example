# Mode
# - gmail_imap (default): Gmail SMTP send + IMAP polling for replies
# - graph: Microsoft Graph send + webhook subscriptions
MAIL_MODE=gmail_imap

# Gmail (requires 2FA + an App Password)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Optional Gmail server overrides
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# Polling (gmail_imap)
POLL_ENABLED=true
POLL_INTERVAL_SECONDS=60

# Teams meeting creation (Microsoft Graph / Entra ID App Registration)
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_ORGANIZER_UPN=

# If you prefer, you can leave TEAMS_* empty and reuse the legacy Graph vars below.

# Legacy Graph mail/webhook settings (only needed if MAIL_MODE=graph)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
SENDER_USER_PRINCIPAL_NAME=
PUBLIC_BASE_URL=
# Any random string; Graph will echo it back in notifications
GRAPH_CLIENT_STATE=change-me

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# App settings
DB_PATH=./data/app.db
APP_BASE_URL=http://localhost:8000
